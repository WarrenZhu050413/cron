{
  "goals": [
    "Description of what this product must become",
    "Who it serves and why it matters"
  ],
  "journeys": [
    "User does X → system responds with Y",
    "Admin does A → data updates correctly"
  ],
  "quality_bar": [
    {
      "criterion": "All tests pass",
      "calibration": {"fail": "any failure", "pass": "0 failures", "high_pass": "0 failures + count increased"}
    },
    {
      "criterion": "No type errors",
      "calibration": {"fail": "type checker errors", "pass": "clean", "high_pass": "clean + strict mode"}
    },
    {
      "criterion": "Production healthy",
      "calibration": {"fail": "health endpoint non-200", "pass": "200 OK", "high_pass": "200 + all endpoints + <500ms"}
    },
    {
      "criterion": "No hardcoded secrets in source",
      "calibration": {"fail": "API key in source", "pass": "all in env vars", "high_pass": "env vars + secret scan in pre-commit"}
    },
    {
      "criterion": "All routes authenticated",
      "calibration": {"fail": "data endpoint without auth", "pass": "auth on all non-public", "high_pass": "auth + ownership + rate limiting"}
    },
    {
      "criterion": "No SQL injection surface",
      "calibration": {"fail": "template literals in SQL", "pass": "parameterized", "high_pass": "parameterized + ORM"}
    },
    {
      "criterion": "Every output interpretable",
      "calibration": {"fail": "black box output", "pass": "shows formula + inputs", "high_pass": "full trace + drill-down"}
    },
    {
      "criterion": "Follows existing design system",
      "calibration": {"fail": "inline styles", "pass": "design tokens + components", "high_pass": "visually indistinguishable from existing"}
    },
    {
      "criterion": "Bug fixes include regression tests",
      "calibration": {"fail": "fix without test", "pass": "test catches the bug", "high_pass": "test + lint rule prevents the class"}
    },
    {
      "criterion": "Test count never decreases",
      "calibration": {"fail": "count decreased", "pass": "same or higher", "high_pass": "increased + covers new code"}
    }
  ]
}
